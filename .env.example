# Database
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=changeme

# If running strictly via Docker, keep @db. 
# If running bare-metal locally, change @db to @localhost !
DATABASE_URL=postgresql+asyncpg://taskflow_user:changeme@localhost:5432/taskflow

# Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRY_HOURS=24

# Backend
BACKEND_PORT=8080
ALLOWED_ORIGINS=["http://localhost:3000"]

# Frontend
VITE_API_URL=http://localhost:8080
